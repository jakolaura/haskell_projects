def unroll_config(config: Config) -> int:  # noqa: C901
    """Unrol the config.

    Repeat every single value / element in list of length 1 so that the attributes are now all lists of equal length.

    Returns:
        int: Length of the unrolled lists.
    """

    def _find_length(config: IsDataclass | list[Any]) -> int:
        """Find the length that all lists share."""
        if isinstance(config, list):
            return len(config)
        if not isinstance(config, IsDataclass):
            return 1

        length: int = 1
        for f in fields(config):
            l = _find_length(getattr(config, f.name))
            if l == 1:
                continue
            if length != 1 and l != length:
                raise ValueError(
                    f"All lists in the config must be of equal length or length 1. '{f.name}' or a list in '{f.name}' "
                    f"has length {l} while at least one other list was of length {length}."
                )
            length = l
        return length

    def _unroll(config: IsDataclass, length: int) -> None:
        """Unroll the lists/single elements in the config to the given length."""
        for f in fields(config):
            val = getattr(config, f.name)
            # Recurse into nested dataclasses...
            if isinstance(val, IsDataclass):
                _unroll(getattr(config, f.name), length)
            # and otherwise expand list.
            elif isinstance(val, list) and len(val) == 1:
                setattr(config, f.name, [val[0]] * length)

    length = _find_length(config)
    _unroll(config, length)
    return length


class _AlgorithmType(IntEnum):
    SDP = auto()
    EXHAUSTIVE = auto()
    CONNECTIONIST = auto()


def _get_preexisting(
    df: pd.DataFrame | None, config: Config, i: int, algorithm_type: _AlgorithmType
) -> dict[tuple[str, str], list[Decimal]]:
    if df is None:
        return {}

    match algorithm_type:
        case _AlgorithmType.SDP:
            existing = df[
                (df[("", "Num. Runs")] == config.num_runs[i])
                & (df[("Graph Config", "Num. Nodes")] == config.graph_config.num_nodes[i])
                & (df[("Graph Config", "Num. Edges")] == config.graph_config.num_edges[i])
                & (df[("Graph Config", "Num. Inherent Valence")] == config.graph_config.num_inherent_valence[i])
                & (df[("Graph Config", "Initial Value")] == config.graph_config.initial_value[i])
                & (df[("Graph Config", "Distribution")] == config.graph_config.distribution[i].name)
                & (df[("Graph Config", "Seed")] == config.graph_config.seed[i])
                & (df[("SDP Relaxation", "Level")] == config.sdp_relaxation_config.level[i])
            ]
        case _AlgorithmType.EXHAUSTIVE:
            existing = df[
                (df[("", "Num. Runs")] == config.num_runs[i])
                & (df[("Graph Config", "Num. Nodes")] == config.graph_config.num_nodes[i])
                & (df[("Graph Config", "Num. Edges")] == config.graph_config.num_edges[i])
                & (df[("Graph Config", "Num. Inherent Valence")] == config.graph_config.num_inherent_valence[i])
                & (df[("Graph Config", "Initial Value")] == config.graph_config.initial_value[i])
                & (df[("Graph Config", "Distribution")] == config.graph_config.distribution[i].name)
                & (df[("Graph Config", "Seed")] == config.graph_config.seed[i])
            ]
        case _AlgorithmType.CONNECTIONIST:
            existing = df[
                (df[("", "Num. Runs")] == config.num_runs[i])
                & (df[("Graph Config", "Num. Nodes")] == config.graph_config.num_nodes[i])
                & (df[("Graph Config", "Num. Edges")] == config.graph_config.num_edges[i])
                & (df[("Graph Config", "Num. Inherent Valence")] == config.graph_config.num_inherent_valence[i])
                & (df[("Graph Config", "Initial Value")] == config.graph_config.initial_value[i])
                & (df[("Graph Config", "Distribution")] == config.graph_config.distribution[i].name)
                & (df[("Graph Config", "Seed")] == config.graph_config.seed[i])
                & (df[("Connectionist Algorithm", "LR")] == config.connectionist_config.lr[i])
                & (df[("Connectionist Algorithm", "Decay")] == config.connectionist_config.decay[i])
                & (
                    df[("Connectionist Algorithm", "Normalisation Function")]
                    == config.connectionist_config.normalisation_function[i].name
                )
                & (df[("Connectionist Algorithm", "Tolerance")] == config.connectionist_config.tolerance[i])
                & (df[("Connectionist Algorithm", "Max. Steps")] == config.connectionist_config.max_steps[i])
            ]

    if existing.empty:
        return {}

    match algorithm_type:
        case _AlgorithmType.SDP:
            return {
                ("SDP Relaxation", "Primal"): [existing.iloc[0][("SDP Relaxation", "Primal")]],
                ("SDP Relaxation", "Dual"): [existing.iloc[0][("SDP Relaxation", "Dual")]],
                ("SDP Relaxation", "Num. Successful"): [existing.iloc[0][("SDP Relaxation", "Num. Successful")]],
            }
        case _AlgorithmType.EXHAUSTIVE:
            return {
                ("Exhaustive Search", "H"): [existing.iloc[0][("Exhaustive Search", "H")]],
            }
        case _AlgorithmType.CONNECTIONIST:
            return {
                ("Connectionist Algorithm", "H"): [existing.iloc[0][("Connectionist Algorithm", "H")]],
                ("Connectionist Algorithm", "Steps Taken"): [
                    existing.iloc[0][("Connectionist Algorithm", "Steps Taken")]
                ],
                ("Connectionist Algorithm", "Num. Converged"): [
                    existing.iloc[0][("Connectionist Algorithm", "Num. Converged")]
                ],
            }


def run_tests(config: Config) -> None:  # noqa: PLR0915
    """Run the test and save the results for the given config."""
    # Ensure dir(s) and file can be created *before* running the simulations.
    config.output.parent.mkdir(parents=True, exist_ok=True)
    config.output.touch(exist_ok=True)

    # Assign None to `df` so that after the first simulation, the `new_df` becomes the `df` and afterward, we only
    #   append to the `df`.
    df: pd.DataFrame | None = None

    # Function used for averaging over the results of multiple runs.
    def _avg(lst: Collection[Decimal]) -> Decimal | None:
        le = len(lst)
        if le == 0:
            return None
        return sum(lst) / Decimal(le)

    # Run simultations.
    num_configs: int = unroll_config(config)
    for i in range(num_configs):
        print(
            f"\n---------- Simulation {i + 1}/{num_configs} ----------\n"
            "Graph Config:\n"
            f"  Num. Nodes: {config.graph_config.num_nodes[i]}\n"
            f"  Num. Edges: {config.graph_config.num_edges[i]}\n"
            f"  Num. Inherent Valence: {config.graph_config.num_inherent_valence[i]}\n"
            f"  Initial Value: {config.graph_config.initial_value[i]}\n"
            f"  Distribution: {config.graph_config.distribution[i].name}\n"
            f"  Seed: {config.graph_config.seed[i]}\n"
            "SDP Relaxation Config:\n"
            f"  Level: {config.sdp_relaxation_config.level[i]}\n"
            "Connectionist Algorithm Config:\n"
            f"  LR: {config.connectionist_config.lr[i]}\n"
            f"  Decay: {config.connectionist_config.decay[i]}\n"
            f"  Normalisation Function: {config.connectionist_config.normalisation_function[i].name}\n"
            f"  Tolerance: {config.connectionist_config.tolerance[i]}\n"
            f"  Max. Steps: {config.connectionist_config.max_steps[i]}\n"
            f"Num. Runs: {config.num_runs[i]}"
            "\n"
        )

        preexisting_sdp = _get_preexisting(df, config, i, _AlgorithmType.SDP)
        preexisting_exhaustive = _get_preexisting(df, config, i, _AlgorithmType.EXHAUSTIVE)
        preexisting_connectionist = _get_preexisting(df, config, i, _AlgorithmType.CONNECTIONIST)

        seed = config.graph_config.seed[i]

        sdp_primal: list[Decimal] = []
        sdp_dual: list[Decimal] = []
        sdp_success: list[bool] = []
        exhaustive_h: list[Decimal] = []
        connectionist_h: list[Decimal] = []
        connectionist_steps_taken: list[int] = []
        connectionist_has_converged: list[bool] = []

        for run in range(config.num_runs[i]):
            print(f"Run {run}: Generating graph...", end='\r')

            # Generate graph.
            graph = generate_graph(
                config.graph_config.num_nodes[i],
                config.graph_config.num_edges[i],
                config.graph_config.num_inherent_valence[i],
                config.graph_config.initial_value[i],
                config.graph_config.distribution[i].build(seed),
                seed,
            )

            # Run SDP relaxation.
            if len(preexisting_sdp) == 0:
                print(f"\033[KRun {run}: Running SDP relaxation...", end='\r')
                sdp_solver = SDPRelaxationSolver(graph)
                sdp_success.append(sdp_solver.solve())
                sdp_primal.append(Decimal(sdp_solver.primal).quantize(ROUNDING_PRECISION))
                sdp_dual.append(Decimal(sdp_solver.dual).quantize(ROUNDING_PRECISION))

            # Run exhaustive search.
            if len(preexisting_exhaustive) == 0:
                print(f"\033[KRun {run}: Running exhaustive search...", end='\r')
                harmony, _ = exhaustive_search(graph.copy())
                exhaustive_h.append(Decimal(harmony).quantize(ROUNDING_PRECISION))

            # Run connectionist algorithm.
            if len(preexisting_connectionist) == 0:
                print(f"\033[KRun {run}: Running connectionist algorithm...", end='\r')
                connectionist_solver = ConnectionistSolver(
                    graph=graph,
                    lr=config.connectionist_config.lr[i],
                    decay=config.connectionist_config.decay[i],
                    normalisation_function=config.connectionist_config.normalisation_function[i].build(),
                    tolerance=config.connectionist_config.tolerance[i],
                    max_steps=config.connectionist_config.max_steps[i],
                )
                connectionist_solver.solve()
                connectionist_h.append(Decimal(connectionist_solver.harmony).quantize(ROUNDING_PRECISION))
                connectionist_steps_taken.append(connectionist_solver.steps_taken)
                connectionist_has_converged.append(connectionist_solver.has_converged)

            print(f"\033[KRun {run}: Finished.")

            seed += 1

        print("-" * (34 + len(str(i + 1)) + len(str(num_configs))))

        results = (
            {
                ("", "Num. Runs"): [config.num_runs[i]],
                ("Graph Config", "Num. Nodes"): [config.graph_config.num_nodes[i]],
                ("Graph Config", "Num. Edges"): [config.graph_config.num_edges[i]],
                ("Graph Config", "Num. Inherent Valence"): [config.graph_config.num_inherent_valence[i]],
                ("Graph Config", "Initial Value"): [config.graph_config.initial_value[i]],
                ("Graph Config", "Distribution"): [config.graph_config.distribution[i].name],
                ("Graph Config", "Seed"): [config.graph_config.seed[i]],
                ("SDP Relaxation", "Level"): [config.sdp_relaxation_config.level[i]],
                ("SDP Relaxation", "Primal"): [_avg(sdp_primal)],
                ("SDP Relaxation", "Dual"): [_avg(sdp_dual)],
                ("SDP Relaxation", "Num. Successful"): [sdp_success.count(True)],
                ("Exhaustive Search", "H"): [_avg(exhaustive_h)],
                ("Connectionist Algorithm", "LR"): [config.connectionist_config.lr[i]],
                ("Connectionist Algorithm", "Decay"): [config.connectionist_config.decay[i]],
                ("Connectionist Algorithm", "Normalisation Function"): [
                    config.connectionist_config.normalisation_function[i].name
                ],
                ("Connectionist Algorithm", "Tolerance"): [config.connectionist_config.tolerance[i]],
                ("Connectionist Algorithm", "Max. Steps"): [config.connectionist_config.max_steps[i]],
                ("Connectionist Algorithm", "H"): [_avg(connectionist_h)],
                ("Connectionist Algorithm", "Steps Taken"): [_avg([Decimal(i) for i in connectionist_steps_taken])],
                ("Connectionist Algorithm", "Num. Converged"): [connectionist_has_converged.count(True)],
            }
            | preexisting_sdp
            | preexisting_exhaustive
            | preexisting_connectionist
        )

        # Put results in DataFrame.
        new_df = pd.DataFrame(results)

        if df is None:
            df = new_df
        else:
            df = pd.concat([df, new_df], ignore_index=True, copy=False)

    print("\nFinished. Saving results...", end='\r')
    out_path: Path = config.output.resolve(strict=True)
    df.to_csv(out_path, index=False)  # type: ignore[reportOptionalMemberAccess]
    print(f"\033[KSaved results to '{out_path}'.")


def _comma_separated_string_to_enum_verified_list(s: str, enum: type[Enum], name: str) -> list[str]:
    values = [v.upper() for v in s.split(',')]
    valid = [e.name for e in enum]
    invalid = [v for v in values if v not in valid]
    if len(invalid) > 0:
        raise argparse.ArgumentTypeError(f"Received invalid {name}(s): {', '.join(invalid)}.")
    return values


def _add_arguments(parser: argparse.ArgumentParser) -> None:
    parser.add_argument('-C', '--config', type=Path, metavar='FILEPATH', help="Path to configuration file.")
    parser.add_argument('-o', '--output', type=Path, metavar='FILEPATH', help="Path to output CSV file.")
    parser.add_argument(
        '-r',
        '--runs',
        '--num-runs',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='num_runs',
        help="Number of different graphs to repeat the measurements for and average the results over. Default: 1.",
    )
    parser.add_argument(
        '-n',
        '--nodes',
        '--num-nodes',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='graph_config.num_nodes',
        help="Number of nodes in the generated graph for all tests or different number of nodes for each test.",
    )
    parser.add_argument(
        '-e',
        '--edges',
        '--num-edges',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='graph_config.num_edges',
        help="Number of edges in the generated graph for all tests or different number of edges for each test.",
    )
    parser.add_argument(
        '-v',
        '--valence',
        '--inherent-valence',
        '--num-valence',
        '--num-inherent-valence',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='graph_config.num_inherent_valence',
        help=(
            "Number of connections to VALENCE in the generated graph for all tests or different number of connections "
            "to VALENCE."
        ),
    )
    parser.add_argument(
        '-i',
        '--initial',
        '--initial-value',
        type=lambda s: list(map(float, s.split(','))),
        metavar='FLOAT[,FLOAT,...]',
        dest='graph_config.initial_value',
        help="Initial value of all valences and activations in the generated graph.",
    )
    parser.add_argument(
        '-D',
        '--distribution',
        type=partial(_comma_separated_string_to_enum_verified_list, enum=Distribution, name="distribution"),
        metavar='FUNC[,FUNC,...]',
        dest='graph_config.distribution',
        help="Distribution to be used by connectionist solver. Options: UNIFORM, TRIANGULAR, NORMAL. Default: UNIFORM",
    )
    parser.add_argument(
        '-s',
        '--seed',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='graph_config.seed',
        help="Seed to be used for generating the graph. Increased after every run (see --num-runs).",
    )
    parser.add_argument(
        '-L',
        '--level',
        '--sdp-level',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='sdp_relaxation_config.level',
        help="Relaxation level to use for the SDP relaxation solver. Default: 2.",
    )
    parser.add_argument(
        '-l',
        '--lr',
        type=lambda s: list(map(float, s.split(','))),
        metavar='FLOAT[,FLOAT,...]',
        dest='connectionist_config.lr',
        help="Learning rate of connectionist solver. Default: 0.5",
    )
    parser.add_argument(
        '-d',
        '--decay',
        type=lambda s: list(map(float, s.split(','))),
        metavar='FLOAT[,FLOAT,...]',
        dest='connectionist_config.decay',
        help="Decay of connectionist solver. Default: 0.05",
    )
    parser.add_argument(
        '-f',
        '--normalisation',
        '--normalisation-function',
        type=partial(
            _comma_separated_string_to_enum_verified_list, enum=NormalisationFunction, name="normalisation function"
        ),
        metavar='FUNC[,FUNC,...]',
        dest='connectionist_config.normalisation_function',
        help="Normalisation function to be used by connectionist solver. Options: MEAN. Default: MEAN",
    )
    parser.add_argument(
        '-t',
        '--tolerance',
        type=lambda s: list(map(float, s.split(','))),
        metavar='FLOAT[,FLOAT,...]',
        dest='connectionist_config.tolerance',
        help=(
            "Convergence threshold of connectionist solver. Stop when changes are smaller than this value. Default: "
            "1e-6."
        ),
    )
    parser.add_argument(
        '-S',
        '--steps',
        '--max-steps',
        type=lambda s: list(map(int, s.split(','))),
        metavar='INT[,INT,...]',
        dest='connectionist_config.max_steps',
        help="Maximum number of steps to run the connectionist solver for. Default: 1000.",
    )


def parse_args() -> Config:
    """Parse arguments with proper priority: CLI > config file."""
    # Set up argparse, parse console arguments.
    parser = argparse.ArgumentParser('test.py')
    _add_arguments(parser)
    args_raw = vars(parser.parse_args())

    # Extract config path.
    config_path: Path | None = args_raw.pop('config', None)

    # Nest args and remove if value is None.
    def insert_at_key(d: dict, keys: list[str], value: Any) -> None:
        if len(keys) > 1:
            key = keys.pop(0)
            if key not in d:
                d[key] = {}
            assert isinstance(d[key], dict)
            insert_at_key(d[key], keys, value)
        else:
            assert keys[0] not in d
            d[keys[0]] = value

    args: dict[str, Any] = {}
    for key, val in args_raw.items():
        if val is not None:
            insert_at_key(args, key.split('.'), val)

    # Convert parsed arguments to Config, parse YAML and combine (console args take priority).
    config = OmegaConf.structured(Config)

    if config_path is not None:
        file_config = OmegaConf.load(config_path)
        config = OmegaConf.merge(config, file_config)

    config = OmegaConf.merge(config, args)

    # Check for missing keys.
    missing = OmegaConf.missing_keys(config)
    if missing:
        print("Missing required configuration values:")
        for key in sorted(missing):  # sort for consistent output
            print(f"  - {key}")
        sys.exit(1)

    # Create config object.
    return cast('Config', OmegaConf.to_object(config))


if __name__ == "__main__":
    config = parse_args()
    run_tests(config)
