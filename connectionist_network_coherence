from typing import cast

import networkx as nx
import sympy
from ncpol2sdpa import SdpRelaxation, generate_variables

from harmony import harmony_term


class SDPRelaxationSolver:
    """Find upper and lower bounds for the optimisation objective's maximum value using SDP relaxation.

    Example:
        ```
        s = SDPRelaxationSolver(graph)
        s.solve()
        s.primal  # upper bound
        s.dual    # lower bound
        ```
    """

    _graph: nx.Graph
    _objective: sympy.Expr
    _inequalities = sympy.Le | sympy.Ge | sympy.Lt | sympy.Gt
    _sdp_relaxation: SdpRelaxation
    _solved: bool

    def __init__(self, graph: nx.Graph) -> None:
        """Initialise SDPRelaxationSolver.

        Args:
            graph (networkx.Graph): Graph to solve.
        """
        self._graph = graph
        self._parse_graph()
        self._solved = False

    def _parse_graph(self) -> None:
        """Parse self._graph and update self._objective, self._inequalities, and self._sdp_relaxation."""
        # setup variables
        num_nodes = len(self._graph.nodes)
        a = generate_variables('a', num_nodes, commutative=True)
        v = generate_variables('v', num_nodes, commutative=True)

        # setup objective
        self._objective = sympy.Float(0)
        for edge in list(self._graph.edges(data=True)):
            self._objective += harmony_term(
                a_i=a[edge[0]],
                a_j=a[edge[1]],
                v_i=v[edge[0]],
                v_j=v[edge[1]],
                w_aj=self._graph.nodes[edge[1]]['w_a'],
                w_vj=self._graph.nodes[edge[1]]['w_v'],
                w_aij=edge[2]['w_a'],
                w_vij=edge[2]['w_v'],
            )
            self._objective += harmony_term(
                a_i=a[edge[1]],
                a_j=a[edge[0]],
                v_i=v[edge[1]],
                v_j=v[edge[0]],
                w_aj=self._graph.nodes[edge[0]]['w_a'],
                w_vj=self._graph.nodes[edge[0]]['w_v'],
                w_aij=edge[2]['w_a'],
                w_vij=edge[2]['w_v'],
            )

        # add inherent valence to objective
        for node in self._graph.nodes(data=True):
            if node[1]['w_inherent_valence'] != 0:
                # same objective term as with other connections but simplified to exclude parts that evaluate to 0
                self._objective += harmony_term(
                    a_i=0,
                    a_j=a[node[0]],
                    v_i=1,
                    v_j=v[node[0]],
                    w_aj=node[1]['w_a'],
                    w_vj=node[1]['w_v'],
                    w_aij=0,
                    w_vij=node[1]['w_inherent_valence'],
                )
                self._objective += harmony_term(
                    a_i=a[node[0]],
                    a_j=0,
                    v_i=v[node[0]],
                    v_j=1,
                    w_aj=0,
                    w_vj=0,
                    w_aij=0,
                    w_vij=node[1]['w_inherent_valence'],
                )

        # negate objective to maximise instead of minimise
        self._objective = -self._objective

        # setup constraints
        self._inequalities = (
            [a_i <= 1 for a_i in a] + [v_i <= 1 for v_i in v] + [a_i >= -1 for a_i in a] + [v_i >= -1 for v_i in v]
        )

        # setup SDP relaxation
        self._sdp_relaxation = SdpRelaxation(a + v)

    def solve(self, level: int = 2) -> bool:
        """Get the SDP relaxation and call a solver on it.

        Params:
            level (int): The level of the relaxation. Try increasing this for a more accurate solution.

        Returns:
            bool: `True` if successful, `False` otherwise. Try increasing `level` if this returns `False`.
        """
        self._sdp_relaxation.get_relaxation(level, self._objective, self._inequalities)
        self._sdp_relaxation.solve('mosek')
        self._solved = True
        return self._sdp_relaxation.status == 'optimal'

    @property
    def primal(self) -> float:
        """The primal SDP value calculated.

        Upper bound of the optimisation problem.
        """
        if not self._solved:
            raise RuntimeError("The graph has not been solved yet. `primal` is only available after calling `solve`.")
        return -cast('float', self._sdp_relaxation.primal)

    @property
    def dual(self) -> float:
        """The dual SDP value calculated.

        Lower bound of the optimisation problem.
        """
        if not self._solved:
            raise RuntimeError("The graph has not been solved yet. `dual` is only available after calling `solve`.")
        return -cast('float', self._sdp_relaxation.dual)

    @property
    def graph(self) -> nx.Graph:
        """Copy of the graph that is/was solved."""
        return self._graph.copy()

    @graph.setter
    def graph(self, graph: nx.Graph) -> None:
        if not isinstance(graph, nx.Graph):
            raise TypeError(f"Expected argument of type `networkx.Graph` but got `{type(graph)}`.")
        self._graph = graph
        self._parse_graph()
        self._solved = False

    @property
    def solved(self) -> bool:
        """Whether the graph has been solved."""
        return self._solved


