ROUNDING_PRECISION = Decimal('1e-6')


@runtime_checkable
class IsDataclass(Protocol):
    """Used for typing dataclasses."""

    __dataclass_fields__: ClassVar[dict[str, Any]]


class Distribution(Enum):
    """Used for specifying which distribution to use."""

    UNIFORM = auto()
    TRIANGULAR = auto()
    NORMAL = auto()

    def build(self, seed: int | None = None) -> Callable[[tuple[int] | int | None], np.ndarray]:
        """Build distribution."""
        rng = np.random.default_rng(seed)

        match self:
            case Distribution.UNIFORM:
                return lambda s: rng.uniform(-1, 1, s)
            case Distribution.TRIANGULAR:
                return lambda s: rng.triangular(-1, 0, 1, s)
            case Distribution.NORMAL:
                return lambda s: np.array(truncnorm.rvs(scale=0.3, a=(-1 / 0.3), b=(1 / 0.3), size=s, random_state=rng))


class NormalisationFunction(Enum):
    """Used for specifying which normalisation function to use."""

    MEAN = auto()

    def build(self) -> Callable[[np.ndarray], np.float64]:
        """Build normalisation function."""
        match self:
            case NormalisationFunction.MEAN:
                return lambda a: a.mean()


