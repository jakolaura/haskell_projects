from collections.abc import Callable
from copy import deepcopy
from dataclasses import dataclass
from functools import wraps
from typing import TypeVar

import networkx as nx
import numpy as np

from graphs import generate_graph
from harmony import harmony

R = TypeVar('R')


class ConnectionistSolver:
    """Connectionist (neural network) solver for emotional coherence model.

    Performs iterative updates of activations (a) and valences (v).
    """

    @dataclass
    class History:
        """Used for keeping track of activations, valences and harmony over time for debugging and analysis."""

        a: list[list[np.float64]]
        v: list[list[np.float64]]
        H: list[np.float64]

    _lr: float
    _decay: float
    _normalisation_function: Callable[[np.ndarray], np.float64]
    _tolerance: float
    _max_steps: int
    _history: History
    _solved: bool
    _has_converged: bool
    _steps_taken: int

    _graph: nx.Graph
    _new_graph: nx.Graph  # Build the _new_graph based on the _graph and then swap.

    def __init__(
        self,
        graph: nx.Graph,
        lr: float = 1.0,
        decay: float = 0.05,
        normalisation_function: Callable[[np.ndarray], np.float64] | None = None,
        tolerance: float = 1e-6,
        max_steps: int = 1000,
    ) -> None:
        """Initialize the ConnectionistSolver.

        Args:
            graph (networkx.Graph): Graph following the same structure as the ones generated by `graphs.generate_graph`.
            lr (float): Learning rate.
            decay (float): Strength of the decay that is applied to the previous valence/activation when updating their
                value.
            normalisation_function (Callable[[np.ndarray], np.float64]): Normalisation function. Maps multiple values
                (impact of the nodes connected to a node) to a single value in range [-1, 1]. If `None`, takes the mean
                of the given values.
            tolerance (float): Convergence threshold. Stop when changes are smaller than this value.
            max_steps (int): Maximum number of update iterations.
        """
        if max_steps < 1:
            raise ValueError(f"`max_steps` must be at least 1 but was {max_steps}.")

        self._graph = graph.copy()
        self._new_graph = graph.copy()
        self._lr = lr
        self._decay = decay

        if normalisation_function is None:
            self._normalisation_function = lambda a: a.mean()
        else:
            self._normalisation_function = normalisation_function

        self._tolerance = tolerance
        self._max_steps = max_steps
        self._history = self.History([], [], [])
        self._solved = False
        self._has_converged = False
        self._steps_taken = 0

    def _update_node(self, node_id: int) -> None:
        """Update the activation (a) and valence (v) of a single node.

        Values are taken from _graph and saved to _new_graph.

        Formulas:
        a_j(t+1) = a_j(t) + ( f(∑_i w_aij * a_i(t)) + w_vj * v_j(t) ) / 2
        v_j(t+1) = v_j(t) + ( f(∑_i w_vij * v_i(t)) + w_aj * a_j(t) ) / 2

        Important naming convention:
        - graph.nodes[node_id]['w_a'] = w_vj (valence --> activation influence)
        - graph.nodes[node_id]['w_v'] = w_aj (activation --> valence influence)

        Args:
            node_id (int): ID of the node to update.

        Returns:
            tuple[float, float]: New (activation, valence) values for the node.
        """
        node_data: dict[str, np.float64] = self._graph.nodes[node_id]

        # Collect influences from neighboring nodes.
        num_neighbours = len(self._graph.edges(node_id, data=True))
        a: np.ndarray = np.empty(num_neighbours + 1, dtype=np.float64)
        v: np.ndarray = np.empty(num_neighbours + 1, dtype=np.float64)
        for i, (_, neighbor, edge_attr) in enumerate(self._graph.edges(node_id, data=True)):
            a[i] = edge_attr['w_a'] * self._graph.nodes[neighbor]['a']
            v[i] = edge_attr['w_v'] * self._graph.nodes[neighbor]['v']

        # Add influence from the node's own valence and activation.
        a[-1] = node_data['w_v'] * node_data['v']
        v[-1] = node_data['w_a'] * node_data['a']

        # Add influence of VALENCE.
        if node_data['w_inherent_valence'] != 0:
            v = np.append(v, node_data['w_inherent_valence'])

        # Apply normalisation function.
        sum_a = self._normalisation_function(a)
        sum_v = self._normalisation_function(v)

        # Compute new activation/valence value.
        a_new = node_data['a'] * (1 - self._decay) + self._lr * sum_a
        v_new = node_data['v'] * (1 - self._decay) + self._lr * sum_v

        # Clip to valid range [-1, 1].
        a_new = a_new.clip(-1, 1)
        v_new = v_new.clip(-1, 1)

        # Assign new activation/valence to graph.
        self._new_graph.nodes[node_id]['a'] = a_new
        self._new_graph.nodes[node_id]['v'] = v_new

    def solve(self) -> None:
        """Run the iterative connectionist algorithm until convergence.

        Updates all nodes simultaneously each iteration.
        Stops when changes are small enough or max_steps is reached.
        """
        # Add initial values to history.
        self._history.H.append(harmony(self._graph))
        self._history.a.append([data['a'] for _, data in self._graph.nodes(data=True)])
        self._history.v.append([data['v'] for _, data in self._graph.nodes(data=True)])

        for step in range(self._max_steps):
            # Update all nodes.
            for node_id in self._graph.nodes:
                self._update_node(node_id)

            # Check convergence by maximum change.
            diff_a: np.ndarray = np.abs(
                [
                    data_new['a'] - data_curr['a']
                    for (_, data_new), (_, data_curr) in zip(
                        self._new_graph.nodes(data=True), self._graph.nodes(data=True), strict=True
                    )
                ]
            )
            diff_v = np.abs(
                [
                    data_new['v'] - data_curr['v']
                    for (_, data_new), (_, data_curr) in zip(
                        self._new_graph.nodes(data=True), self._graph.nodes(data=True), strict=True
                    )
                ]
            )

            max_diff: np.float64 = max(np.max(diff_a), np.max(diff_v))

            # Update history.
            self._history.H.append(harmony(self._new_graph))
            self._history.a.append([data['a'] for _, data in self._new_graph.nodes(data=True)])
            self._history.v.append([data['v'] for _, data in self._new_graph.nodes(data=True)])

            # Swap graphs.
            self._graph, self._new_graph = self._new_graph, self._graph

            # Stop if converged.
            if max_diff < self._tolerance:
                self._steps_taken = step + 1  # Add 1 because indexing starts at 0.
                self._solved = True
                self._has_converged = True
                return

        self._steps_taken = step + 1  # type: ignore[reportPossiblyUnboundVariable]
        self._solved = True

    @staticmethod
    def _reset(func: Callable[..., R]) -> Callable[..., R]:
        @wraps(func)
        def wrapper(self: ConnectionistSolver, *args, **kwargs) -> R:
            self._solved = False
            self._has_converged = False
            self._steps_taken = 0
            self._history = self.History([], [], [])
            return func(self, *args, **kwargs)

        return wrapper

    @staticmethod
    def _requires_solved(func: Callable[..., R]) -> Callable[..., R]:
        @wraps(func)
        def wrapper(self: ConnectionistSolver, *args, **kwargs) -> R:
            if not self._solved:
                raise RuntimeError(
                    f"Cannot access `{func.__name__}` before calling `solve`. If you change any properties, `solve` "
                    "must be called again."
                )
            return func(self, *args, **kwargs)

        return wrapper

    @property
    def lr(self) -> float:
        """Learning rate."""
        return self._lr

    @lr.setter
    @_reset
    def lr(self, value: float) -> None:
        self._lr = value

    @property
    def decay(self) -> float:
        """Decay."""
        return self._decay

    @decay.setter
    @_reset
    def decay(self, value: float) -> None:
        self._decay = value

    @property
    def normalisation_function(self) -> Callable[[np.ndarray], np.float64]:
        """Reference to normalisation function.

        Maps multiple values (impact of the nodes connected to a node) to a single value in range [-1, 1]. If `None`,
        takes the mean of the given values.
        """
        return self._normalisation_function

    @normalisation_function.setter
    @_reset
    def normalisation_function(self, value: Callable[[np.ndarray], np.float64]) -> None:
        self._normalisation_function = value

    @property
    def tolerance(self) -> float:
        """Convergence threshold. Stop when changes are smaller than this value."""
        return self._tolerance

    @tolerance.setter
    @_reset
    def tolerance(self, value: float) -> None:
        self._tolerance = value

    @property
    def max_steps(self) -> int:
        """Maximum number of update iterations."""
        return self._max_steps

    @max_steps.setter
    @_reset
    def max_steps(self, value: int) -> None:
        self._max_steps = value

    @property
    @_requires_solved
    def history(self) -> History:
        """History keeping track of activations, valences and harmony over time for debugging and analysis."""
        return deepcopy(self._history)

    @property
    @_requires_solved
    def harmony(self) -> np.float64:
        """Harmony of the final assignment that the network converged to."""
        return self._history.H[-1]

    @property
    def solved(self) -> bool:
        """Whether the graph has been solved."""
        return self._solved

    @property
    @_requires_solved
    def has_converged(self) -> bool:
        """True if the algorithm has converged rather than stopped because of reaching the maximum steps."""
        return self._has_converged

    @property
    @_requires_solved
    def steps_taken(self) -> int:
        """The number of steps taken for finding the solution."""
        return self._steps_taken

    @property
    def graph(self) -> nx.Graph:
        """A copy of the solved graph or unsolved graph if `solve` hasn't been called yet."""
        return self._graph.copy()

    @graph.setter
    @_reset
    def graph(self, graph: nx.Graph) -> None:
        self._graph = graph.copy()
        self._new_graph = graph.copy()


# Example
if __name__ == "__main__":
    print("Example")  # noqa: T201

    graph = generate_graph(4, 5, 1, seed=42)  # 4 nodes, 5 edges, 1 inherent valence node, seed for reproducibility

    solver = ConnectionistSolver(graph=graph, tolerance=1e-4, max_steps=500)
    final_harmony = solver.solve()

    print("\nFinal values:")  # noqa: T201
    for node in graph.nodes():
        print(f"  Node {node}: a = {solver.history.a[-1][node]:.4f}, v = {solver.history.v[-1][node]:.4f}")  # noqa: T201

    print(f"\n--->Final harmony H = {solver.history.H[-1]:.4f}")  # noqa: T201
    print("Exit!")  # noqa: T201

import networkx as nx
import numpy as np

from graphs import generate_graph
from harmony import harmony


def exhaustive_search(graph: nx.Graph) -> tuple[int, nx.Graph]:
    """Find the maximum assignment of the graph using exhaustive search.

    This only considers the values 1 and -1 for activation and valence of the nodes.

    Params:
        graph (networkx.Graph): Networkx graph object made with graphs.py.

    Returns:
        int: Maximum value (calculated with harmony).
        networkx.Graph: Maximum graph associated with maximum value.
    """

    def _exhaustive_search(graph: nx.Graph, n: int) -> None:
        """Helper function: Recursively assign all combinations of 1 and -1 and calculates the harmony.

        Params:
            graph (networkx.Graph): Networkx graph object.
            n (int): Initial value the number of nodes in the graph.
        """
        if n == 0:  # if all nodes have been assigned
            objective_scores.append(harmony(graph))  # add harmony score
            graph_list.append(graph)  # add graph
        else:
            for i in [-1, 1]:
                for j in [-1, 1]:
                    graph_copy = graph.copy()
                    node = graph_copy.nodes(data=True)[n - 1]  # select node n (n-1 because index starts at 0)
                    node['a'] = i  # assign value to activation
                    node['v'] = j  # assign value to valence
                    _exhaustive_search(graph_copy, n - 1)  # recursively call function with n-1
        #### end of exhaustive_search_()

    objective_scores = []
    graph_list = []

    _exhaustive_search(graph, len(graph))

    max_idx = np.argmax(objective_scores)  # select index of highest harmony score
    return objective_scores[max_idx], graph_list[max_idx]


if __name__ == "__main__":
    # Example
    graph = generate_graph(6, 10, 1, seed=42)
    max_value, max_graph = exhaustive_search(graph)
    print(f"Maximum objective value: {max_value}")  # noqa: T201
    print(  # noqa: T201
        f"Maximum assignment (node,a,v): {[(node, data['a'], data['v']) for node, data in max_graph.nodes(data=True)]}"
    )

from collections.abc import Callable

import networkx as nx
import numpy as np


def generate_graph(
    num_nodes: int,
    num_edges: int,
    num_inherent_valence: int,
    initial_value: float | np.float64 = 0,
    distribution: Callable[[tuple[int] | int | None], np.ndarray] | None = None,
    seed: int | None = None,
) -> nx.Graph:
    """Create a random graph with `num_nodes`, `num_edges` and weights drawn from `distribution`.

    Params:
        num_nodes (int): Number of nodes the graph should have.
        num_edges (int): Number of edges the graph should have.
        num_inherent_valence (int): Number of edges that have inherent valence attached to them.
        initial_value (float): Initial value assigned to activations and valences. Defaults to `0`.
        distribution (Callable[[tuple[int] | int | None], np.ndarray] | None): Distributions to draw the weights from.
            The values should be in range [-1, 1]. For w_ai and w_vi, they are rescaled to [0, 1]. The `Callable` should
            take a shape and return an `np.ndarray` of that shape with random values. If `None`, sample from uniform
            distribution.
        seed (int): Seed for reproducibility. Defaults to `None`(unpredictable entropy from OS).

    Returns:
        networkx.Graph: The random graph.
    """
    if num_edges > (m := num_nodes * (num_nodes - 1) // 2):
        raise ValueError(
            f"num_edges must be at most {m} for {num_nodes} nodes but was {num_edges}. Graph can have at "
            "most (|V| (|V| - 1)) / 2 edges, in which case it is complete."
        )

    if distribution is None:
        distribution = lambda s: np.random.default_rng(seed).uniform(-1, 1, s)  # noqa: E731

    graph: nx.Graph = nx.gnm_random_graph(num_nodes, num_edges, seed=seed)

    # assign edge weights
    #  between nodes
    nx.set_edge_attributes(graph, dict(zip(graph.edges, distribution(graph.number_of_edges()), strict=True)), 'w_a')
    nx.set_edge_attributes(graph, dict(zip(graph.edges, distribution(graph.number_of_edges()), strict=True)), 'w_v')
    #  within nodes
    nx.set_node_attributes(
        graph, dict(zip(graph.nodes, (distribution(graph.number_of_nodes()) + 1) / 2, strict=True)), 'w_a'
    )
    nx.set_node_attributes(
        graph, dict(zip(graph.nodes, (distribution(graph.number_of_nodes()) + 1) / 2, strict=True)), 'w_v'
    )

    # assign activation/valence weights
    nx.set_node_attributes(graph, np.float64(initial_value), 'a')  # type: ignore[reportArgumentType, reportCallIssue]
    nx.set_node_attributes(graph, np.float64(initial_value), 'v')  # type: ignore[reportArgumentType, reportCallIssue]

    # assign inherent valence
    nx.set_node_attributes(graph, np.float64(0), 'w_inherent_valence')  # type: ignore[reportArgumentType, reportCallIssue]
    selected_nodes = np.random.default_rng(seed).choice(np.array(graph.nodes), num_inherent_valence, replace=False)
    nx.set_node_attributes(
        graph, dict(zip(selected_nodes, distribution(len(selected_nodes)), strict=True)), 'w_inherent_valence'
    )

    return graph


# Example
if __name__ == "__main__":
    graph = generate_graph(6, 10, 2, seed=42)
    print("Nodes:")  # noqa: T201
    for node, data in graph.nodes(data=True):
        print(f"    Node {node}:\t{data}")  # noqa: T201
    print("Edges:")  # noqa: T201
    for node1, node2, data in graph.edges(data=True):
        print(f"    Edge ({node1}, {node2}):\t{data}")  # noqa: T201

from __future__ import annotations

from typing import TYPE_CHECKING, Any, Protocol, cast

import numpy as np

if TYPE_CHECKING:
    from networkx import Graph


class _SupportsAddMul(Protocol):
    def __add__(self, *args, **kwargs) -> Any: ...

    def __radd__(self, *args, **kwargs) -> Any: ...

    def __mul__(self, *args, **kwargs) -> Any: ...

    def __rmul__(self, *args, **kwargs) -> Any: ...


def harmony(graph: Graph) -> np.float64:
    """Compute the harmony H (optimization objective) of the given graph.

    H = ∑_i ∑_j [w_aij * a_i * (a_j + w_vj * v_j) + w_vij * v_i * (v_j + w_aj * a_j)]

    Returns:
        float: Current harmony value H.
    """
    H = np.float64(0)

    # Add harmony for all edges.
    for i, j, edge_attr in graph.edges(data=True):
        node_i: dict[str, np.float64] = graph.nodes[i]
        node_j: dict[str, np.float64] = graph.nodes[j]

        H += harmony_term(
            a_i=node_i['a'],
            a_j=node_j['a'],
            v_i=node_i['v'],
            v_j=node_j['v'],
            w_aj=node_j['w_a'],
            w_vj=node_j['w_v'],
            w_aij=edge_attr['w_a'],
            w_vij=edge_attr['w_v'],
        )
        H += harmony_term(
            a_i=node_j['a'],
            a_j=node_i['a'],
            v_i=node_j['v'],
            v_j=node_i['v'],
            w_aj=node_i['w_a'],
            w_vj=node_i['w_v'],
            w_aij=edge_attr['w_a'],
            w_vij=edge_attr['w_v'],
        )

    # Add harmony for all inherent valences.
    for _, data in graph.nodes(data=True):
        if data['w_inherent_valence'] == 0:
            continue

        H += harmony_term(
            a_i=0,
            a_j=data['a'],
            v_i=1,
            v_j=data['v'],
            w_aj=data['w_a'],
            w_vj=data['w_v'],
            w_aij=0,
            w_vij=data['w_inherent_valence'],
        )
        H += harmony_term(
            a_i=data['a'],
            a_j=0,
            v_i=data['v'],
            v_j=1,
            w_aj=0,
            w_vj=0,
            w_aij=0,
            w_vij=data['w_inherent_valence'],
        )

    return cast('np.float64', H)


def harmony_term(
    a_i: _SupportsAddMul,
    a_j: _SupportsAddMul,
    v_i: _SupportsAddMul,
    v_j: _SupportsAddMul,
    w_aj: _SupportsAddMul,
    w_vj: _SupportsAddMul,
    w_aij: _SupportsAddMul,
    w_vij: _SupportsAddMul,
) -> _SupportsAddMul:
    """Calculate one term in the sum of the harmony."""
    return w_aij * a_i * (a_j + w_vj * v_j) + w_vij * v_i * (v_j + w_aj * a_j)

